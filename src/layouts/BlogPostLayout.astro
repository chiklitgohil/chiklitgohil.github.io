---
import BaseLayout from "./BaseLayout.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  headings?: Heading[];
}

const { title, description, date, tags = [], headings = [] } = Astro.props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={title} description={description} wide>
  <main class="mx-auto grid max-w-6xl gap-10 pt-16 lg:grid-cols-[minmax(0,760px)_220px]">
    <article class="min-w-0">
      <a class="text-sm font-medium text-zinc-400 underline decoration-zinc-700 underline-offset-4 transition-colors hover:text-white" href="/blog">
        Back to blog
      </a>
      <header class="mt-6 border-b border-zinc-800 pb-8">
        <p class="text-sm text-yellow-300">
          {date.toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric" })}
        </p>
        <h1 class="mt-3 text-4xl font-bold leading-tight text-white sm:text-5xl">{title}</h1>
        <p class="mt-4 text-lg leading-8 text-zinc-300">{description}</p>
        {
          tags.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-2">
              {tags.map((tag) => <li class="rounded-full border border-zinc-700 px-2.5 py-1 text-xs text-zinc-300">{tag}</li>)}
            </ul>
          )
        }
      </header>
      <div class="prose-lite mt-8">
        <slot />
      </div>
    </article>
    {
      toc.length > 0 && (
        <aside class="sticky top-24 hidden h-fit rounded-xl border border-zinc-800 bg-zinc-900/70 p-4 lg:block">
          <p class="text-sm font-semibold text-white">On this page</p>
          <nav class="mt-3 flex flex-col gap-2 text-sm text-zinc-400">
            {toc.map((heading) => (
              <a class={heading.depth === 3 ? "pl-3 transition-colors hover:text-white" : "transition-colors hover:text-white"} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            ))}
          </nav>
        </aside>
      )
    }
  </main>
</BaseLayout>
