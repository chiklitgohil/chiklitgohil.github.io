---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactFooter from "@components/ContactFooter.astro";
import Icon from "@components/Icon.astro";
import SectionIntro from "@components/SectionIntro.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog" description="Markdown-powered writing by Chiklit Gohil.">
  <main class="pt-16">
    <SectionIntro
      title="Blog"
      eyebrow="Writing"
      description="Notes on projects, computer science, AI experiments, and the lessons that come from building things."
    />
    <div class="grid gap-4">
      {
        posts.map((post) => (
          <a class="group rounded-xl border border-zinc-700/60 bg-zinc-800/70 p-4 transition-colors hover:border-yellow-300/70 sm:p-5" href={`/blog/${post.slug}`}>
            <div class="flex items-start justify-between gap-5">
              <div>
                <p class="text-sm text-yellow-300">
                  {post.data.date.toLocaleDateString("en", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
                <h2 class="mt-2 text-xl font-semibold text-white">{post.data.title}</h2>
                <p class="mt-2 text-sm leading-6 text-zinc-300 sm:text-base sm:leading-7">{post.data.description}</p>
              </div>
              <Icon name="external" class="mt-1 h-4 w-4 shrink-0 text-zinc-500 transition-colors group-hover:text-yellow-300" />
            </div>
            {
              post.data.tags.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => <li class="rounded-full border border-zinc-700 px-2.5 py-1 text-xs text-zinc-300">{tag}</li>)}
                </ul>
              )
            }
          </a>
        ))
      }
    </div>
  </main>
  <ContactFooter />
</BaseLayout>
