---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactFooter from "@components/ContactFooter.astro";
import SectionIntro from "@components/SectionIntro.astro";
import WorkCard from "@components/WorkCard.astro";
import { work } from "@data/content";
---

<BaseLayout title="Work" description="Work experience by Chiklit Gohil.">
  <main class="pt-16">
    <SectionIntro
      title="Work"
      eyebrow="Experience"
      description="Internships and freelance work that shaped how I think about products, clients, teams, and code."
    />
    <div class="grid gap-4">
      {work.map((item) => <WorkCard item={item} />)}
    </div>
  </main>
  <ContactFooter />
</BaseLayout>
