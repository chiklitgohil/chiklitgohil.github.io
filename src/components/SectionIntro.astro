---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  href?: string;
  linkLabel?: string;
}

const { title, eyebrow, description, href, linkLabel } = Astro.props;
---

<div class="mb-5 mt-16 flex items-end justify-between gap-5 sm:mb-7 sm:mt-20">
  <div>
    {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-yellow-300">{eyebrow}</p>}
    <h2 class="text-xl font-semibold text-white sm:text-2xl">{title}</h2>
    {description && <p class="mt-2 max-w-2xl text-base leading-7 text-zinc-400 sm:text-lg">{description}</p>}
  </div>
  {
    href && linkLabel && (
      <a class="hidden shrink-0 text-sm font-medium text-zinc-300 underline decoration-zinc-600 underline-offset-4 transition-colors hover:text-white sm:inline" href={href}>
        {linkLabel}
      </a>
    )
  }
</div>
