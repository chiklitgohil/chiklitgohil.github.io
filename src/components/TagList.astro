---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="mt-4 flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <li class="rounded-full border border-zinc-700 bg-zinc-900/70 px-2.5 py-1 text-xs leading-none text-zinc-300">
        {tag}
      </li>
    ))
  }
</ul>
