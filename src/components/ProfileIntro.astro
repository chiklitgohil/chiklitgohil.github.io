---
import { site } from "@data/site";
---

<section class="animate-fade-up pt-16 sm:pt-20">
  <div class="mb-6 flex items-center gap-4 sm:mb-8 sm:gap-5">
    <img
      src={site.profileImage}
      class="h-[65px] w-[65px] rounded-full border border-zinc-700 object-cover sm:h-[80px] sm:w-[80px]"
      alt="Chiklit Gohil"
    />
    <div class="flex flex-col gap-0.5">
      <h1 class="text-xl font-semibold text-white sm:text-3xl sm:font-bold">
        {site.name}
      </h1>
      <span class="hidden text-base text-zinc-300 sm:block sm:text-lg">
        {site.longSubtitle}
      </span>
      <span class="block text-base text-zinc-300 sm:hidden">{site.shortSubtitle}</span>
    </div>
  </div>
</section>
