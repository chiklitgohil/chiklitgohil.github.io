---
import Icon from "./Icon.astro";
import TagList from "./TagList.astro";

interface Props {
  item: {
    title: string;
    type: string;
    location: string;
    period: string;
    summary: string[];
    technologies: string[];
    details: string[];
  };
}

const { item } = Astro.props;
---

<article class="rounded-xl border border-zinc-700/60 bg-zinc-800/70 p-4 shadow-lg shadow-black/10 sm:p-5">
  <div class="flex flex-col gap-2 text-xs uppercase tracking-[0.16em] text-zinc-500 sm:flex-row sm:items-center sm:justify-between">
    <span>{item.location}</span>
    <span>{item.period}</span>
  </div>
  <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-center">
    <h3 class="text-lg font-semibold text-white sm:text-xl">{item.title}</h3>
    <span class="w-fit rounded-full bg-zinc-700 px-2.5 py-1 text-xs font-medium leading-none text-zinc-200">
      {item.type}
    </span>
  </div>
  <div class="mt-4 flex flex-col gap-3 text-sm leading-6 text-zinc-300 sm:text-base sm:leading-7">
    {item.summary.map((paragraph) => <p>{paragraph}</p>)}
  </div>
  <TagList tags={item.technologies} />

  {
    item.details.length > 0 && (
      <details class="group mt-5 rounded-lg border border-zinc-700/60 bg-zinc-900/60">
        <summary class="flex cursor-pointer items-center justify-between gap-4 px-4 py-3 text-sm font-medium text-zinc-200">
          Detailed experience
          <Icon name="chevron" class="h-4 w-4 transition-transform group-open:rotate-180" />
        </summary>
        <ul class="space-y-3 border-t border-zinc-700/60 px-4 py-4 text-sm leading-6 text-zinc-300">
          {item.details.map((detail) => <li class="pl-4 before:-ml-4 before:mr-2 before:text-yellow-300 before:content-['-']">{detail}</li>)}
        </ul>
      </details>
    )
  }
</article>
