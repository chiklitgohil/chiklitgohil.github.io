---
import Icon from "./Icon.astro";
import { navItems, site } from "@data/site";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);
---

<header class="sticky top-0 z-50 pt-5">
  <nav class="mx-auto flex min-h-12 max-w-[760px] items-center justify-between gap-5 rounded-3xl border border-zinc-700/50 bg-zinc-800/95 px-5 text-base text-zinc-400 shadow-xl shadow-black/20 backdrop-blur sm:px-6">
    <button
      id="mobile-menu-open"
      type="button"
      class="flex items-center py-3 transition-colors hover:text-zinc-100 sm:hidden"
      aria-label="Open navigation"
    >
      <Icon name="menu" class="h-[18px] w-[18px]" />
    </button>

    <div class="hidden items-center gap-6 sm:flex">
      {
        navItems.map((item) => (
          <a
            class="relative flex items-center gap-2 py-3 pr-1 text-sm transition-colors hover:text-zinc-100 sm:text-base"
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            <Icon name={item.icon} class="h-4 w-4" />
            {item.label}
            {isActive(item.href) && (
              <span class="absolute -bottom-px left-0 right-0 h-px bg-gradient-to-r from-zinc-400/0 via-zinc-300/60 to-zinc-400/0" />
            )}
          </a>
        ))
      }
    </div>

    <a
      class="relative flex items-center gap-2 py-3 pr-1 text-sm transition-colors hover:text-zinc-100 sm:text-base"
      href={`mailto:${site.email}`}
    >
      <Icon name="message" class="h-4 w-4" />
      Say Hi
      <span class="absolute -bottom-px left-0 right-0 h-px bg-gradient-to-r from-yellow-300/0 via-yellow-300/60 to-yellow-300/0"></span>
    </a>
  </nav>

  <div
    id="mobile-menu"
    class="fixed inset-0 z-[60] hidden bg-zinc-950/95 px-6 py-6 text-zinc-100 backdrop-blur"
  >
    <button
      id="mobile-menu-close"
      type="button"
      class="mb-12 flex rounded-xl border border-zinc-700 p-3 text-zinc-300 transition-colors hover:text-white"
      aria-label="Close navigation"
    >
      <Icon name="close" class="h-5 w-5" />
    </button>
    <div class="flex flex-col gap-5">
      {
        navItems.map((item) => (
          <a class="flex items-center gap-3 text-2xl font-semibold" href={item.href}>
            <Icon name={item.icon} class="h-6 w-6 text-yellow-300" />
            {item.label}
          </a>
        ))
      }
      <a class="flex items-center gap-3 text-2xl font-semibold" href="/#contact">
        <Icon name="mail" class="h-6 w-6 text-yellow-300" />
        Contact
      </a>
    </div>
  </div>
</header>

<script>
  const menu = document.getElementById("mobile-menu");
  const openButton = document.getElementById("mobile-menu-open");
  const closeButton = document.getElementById("mobile-menu-close");
  const links = menu?.querySelectorAll("a") ?? [];

  function setMenu(open: boolean) {
    menu?.classList.toggle("hidden", !open);
    document.body.style.overflow = open ? "hidden" : "";
  }

  openButton?.addEventListener("click", () => setMenu(true));
  closeButton?.addEventListener("click", () => setMenu(false));
  links.forEach((link) => link.addEventListener("click", () => setMenu(false)));
</script>
