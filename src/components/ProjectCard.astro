---
import Icon from "./Icon.astro";
import TagList from "./TagList.astro";

interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  project: {
    name: string;
    role: string;
    description: string;
    technologies: string[];
    links?: LinkItem[];
    video?: string;
  };
}

const { project } = Astro.props;
---

<article class="overflow-hidden rounded-xl border border-zinc-700/60 bg-zinc-800/70 p-4 shadow-lg shadow-black/10">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
        <h3 class="text-lg font-semibold text-white sm:text-xl">{project.name}</h3>
        <span class="w-fit rounded-full bg-yellow-300 px-2.5 py-1 text-xs font-semibold leading-none text-yellow-950">
          {project.role}
        </span>
      </div>
      <p class="mt-3 text-sm leading-6 text-zinc-300 sm:text-base sm:leading-7">
        {project.description}
      </p>
    </div>
    <Icon name="folder" class="mt-1 hidden h-5 w-5 text-zinc-500 sm:block" />
  </div>

  {
    project.video && (
      <div class="mt-4 overflow-hidden rounded-lg border border-zinc-700 bg-zinc-950">
        <iframe
          class="aspect-video w-full"
          src={project.video}
          title={`${project.name} video`}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
      </div>
    )
  }

  <TagList tags={project.technologies} />

  {
    project.links && project.links.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-4 border-t border-zinc-700/60 pt-4">
        {project.links.map((link) => (
          <a class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-200 underline decoration-zinc-600 underline-offset-4 transition-colors hover:text-white" href={link.href} target="_blank" rel="noreferrer">
            {link.label}
            <Icon name="external" class="h-3.5 w-3.5" />
          </a>
        ))}
      </div>
    )
  }
</article>
